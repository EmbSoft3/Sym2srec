################################################################################
# OS Detection + Shell
#
# On Windows, Make is forced to use sh.exe from MSYS2 or Git Bash.
# Unix tools (find, rm, cat, cp) are then called via their absolute path
# to prevent Windows from intercepting them with its own commands
# (e.g. FIND.EXE, which is a string search tool, not a file finder).
#
# Windows prerequisites (one is enough):
#   - MSYS2       : https://www.msys2.org/        (recommended)
#   - Git Bash    : https://git-scm.com/
#
# Update MSYS2_BIN or GITBASH_BIN if your installation path differs.
################################################################################

ifeq ($(OS),Windows_NT)
  PLATFORM := Windows

  MSYS2_BIN   := C:/msys64/usr/bin
  GITBASH_BIN := C:/Program Files/Git/usr/bin

  ifneq ($(wildcard $(MSYS2_BIN)/sh.exe),)
    SHELL    := $(MSYS2_BIN)/sh.exe
    UNIX_BIN := $(MSYS2_BIN)
  else ifneq ($(wildcard $(GITBASH_BIN)/sh.exe),)
    SHELL    := $(GITBASH_BIN)/sh.exe
    UNIX_BIN := $(GITBASH_BIN)
  else
    $(error No Unix shell found. Install MSYS2 (https://www.msys2.org) \
            or Git for Windows (https://git-scm.com) and update MSYS2_BIN.)
  endif

  # Absolute paths to Unix tools to prevent Windows from hijacking them
  RM := $(UNIX_BIN)/rm -rf

else
  PLATFORM := Unix
  RM := rm -rf
endif

################################################################################
# Path
################################################################################

SOURCES_PATH  := ../src
INCLUDES_PATH := ../include

################################################################################
# Toolchain
#
# On Windows: MinGW-w64 is used. Update MINGW_PATH if your installation differs.
# On Linux  : the system gcc/g++ are used directly.
################################################################################

ifeq ($(OS),Windows_NT)
  MINGW_PATH := C:/MinGWToolchain/sjlj/mingw32/bin
  CC := @$(MINGW_PATH)/gcc
  LL := @$(MINGW_PATH)/g++
else
  CC := @gcc
  LL := @g++
endif

################################################################################
# Artefacts
################################################################################

BUILD_ARTIFACT_NAME      := sym2srec
ifeq ($(OS),Windows_NT)
  BUILD_ARTIFACT_EXTENSION := exe
else
  BUILD_ARTIFACT_EXTENSION :=
endif
BUILD_ARTIFACT := $(BUILD_ARTIFACT_NAME)$(if $(BUILD_ARTIFACT_EXTENSION),.$(BUILD_ARTIFACT_EXTENSION),)

################################################################################
# Compiler/Linker Options
################################################################################

# Optimization Options
OPTIMIZATION_OPTIONS := -O0

# Options to Request or Suppress Warnings
WARN_OPTIONS := -pedantic -Wall -Wextra -Wconversion -Wcast-align -Wcast-qual \
  -Wdisabled-optimization -Wlogical-op -Wmissing-declarations \
  -Wmissing-include-dirs -Wredundant-decls -Wshadow -Wsign-conversion \
  -Wswitch-default -Wundef -Wwrite-strings -Wfloat-equal

# Linking Options
LD_OPTIONS := -m32 -s -static

# H flags
H_FLAGS := -I$(INCLUDES_PATH)

# C flags
C_FLAGS := $(OPTIMIZATION_OPTIONS) $(WARN_OPTIONS) -fmessage-length=0 -m32 \
           -MMD -MP

# Linker flags
LD_FLAGS := $(LD_OPTIONS) -o "$(BUILD_ARTIFACT)"

################################################################################
# List
################################################################################

INCLUDE_LIST := $(wildcard $(INCLUDES_PATH)/*.h)
OBJECT_LIST  := sym2srec_hash.o sym2srec_main.o sym2srec_srecord.o sym2srec_utils.o

# Dependency files (auto-generated by -MMD)
DEP_LIST := $(OBJECT_LIST:.o=.d)

# Include auto-generated dependency files (silent if not yet present)
-include $(DEP_LIST)

################################################################################
# Clean Target
################################################################################

clean:
ifneq ($(strip $(wildcard *.o)),)
	$(RM) $(OBJECT_LIST)
endif
ifneq ($(strip $(wildcard *.d)),)
	$(RM) $(DEP_LIST)
endif
ifneq ($(strip $(wildcard *.exe)),)
	$(RM) $(BUILD_ARTIFACT)
endif
ifeq ($(PLATFORM),Unix)
ifneq ($(strip $(wildcard $(BUILD_ARTIFACT_NAME))),)
	$(RM) $(BUILD_ARTIFACT_NAME)
endif
endif

################################################################################
# C Source Target
################################################################################

%.o: $(SOURCES_PATH)/%.c $(INCLUDE_LIST)
	@echo "  CC  $<"
	$(CC) $(C_FLAGS) $(H_FLAGS) -o $@ -c $<

################################################################################
# Link Target
################################################################################

$(BUILD_ARTIFACT): $(OBJECT_LIST)
	@echo "  LD  $@"
	$(LL) $(LD_FLAGS) $(OBJECT_LIST)
	@echo "  => $(BUILD_ARTIFACT) built."

################################################################################
# All Target
################################################################################

all: $(BUILD_ARTIFACT)

################################################################################
# Phony
################################################################################

.PHONY: all clean
